{
  "name": "nexuscompress",
  "version": "2.2.29",
  "description": "Client-side image optimizer with CLI",
  "main": "cli.js",
  "bin": {
    "nexus-compress": "./cli.js"
  },
  "scripts": {
    "build": "BUMP_ON_BUILD=1 node scripts/build.js",
    "build:css": "postcss src/styles/main.css -o public/css/app.css && node scripts/sync-version.js && node scripts/sync-public-assets.js",
    "version:sync": "node scripts/sync-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "dev": "npm run build:css && node scripts/dev-server.js",
    "preview": "npm run build && node scripts/preview-server.js",
    "start": "npm run preview",
    "test": "SKIP_VERSION_BUMP=1 npm run build && node test.js",
    "compress": "node cli.js",
    "predeploy": "rm -rf dist && npm run build && node scripts/verify-dist.js",
    "deploy": "wrangler deploy",
    "postinstall": "node scripts/vendor-jszip.js && node scripts/vendor-pdf-lib.js && node scripts/vendor-sentry.js && node scripts/vendor-heic-to.js && node scripts/generate-icons.js && node scripts/generate-og.js"
  },
  "keywords": [
    "image",
    "compress",
    "webp",
    "avif",
    "optimizer"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/outfit": "^5.2.5",
    "@fontsource/syne": "^5.2.7",
    "cssnano": "^7.0.6",
    "express": "^5.2.1",
    "heic-to": "^1.4.3",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "puppeteer": "^25.0.4",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  }
}
