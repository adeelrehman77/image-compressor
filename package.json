{
  "name": "nexuscompress",
  "version": "2.1.0",
  "description": "Client-side image optimizer with CLI",
  "main": "cli.js",
  "bin": {
    "nexus-compress": "./cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:css": "postcss src/styles/main.css -o public/css/app.css && node scripts/patch-html.js",
    "prebuild": "node scripts/patch-html.js",
    "dev": "npm run build:css && node scripts/dev-server.js",
    "preview": "npm run build && node scripts/preview-server.js",
    "start": "npm run preview",
    "test": "npm run build && node test.js",
    "compress": "node cli.js",
    "pages:deploy": "npm run build && npx wrangler deploy",
    "postinstall": "node scripts/vendor-jszip.js && node scripts/generate-icons.js && node scripts/generate-og.js"
  },
  "keywords": ["image", "compress", "webp", "avif", "optimizer"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/outfit": "^5.2.5",
    "cssnano": "^7.0.6",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "puppeteer": "^25.0.4",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  }
}
